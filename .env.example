# =============================================================================
# MagikBook API Environment Configuration
# =============================================================================

# =============================================================================
# Core Settings
# =============================================================================

# Database URL
# SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./magikbook.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/magikbook

# Redis — ежедневный бонус маны, лимиты анонимов, battle→ELO, брокер arq.
# Пусто → in-memory в одном процессе API (не для нескольких реплик).
# Локально: redis://localhost:6379/0
# В /opt/projects/docker-compose.yml для magikbook-api и magikbook-worker задаётся
# REDIS_URL=redis://magikbook-redis:6379/0 (перекрывает пустое значение здесь).
REDIS_URL=

# Security
SECRET_KEY=change-this-secret-key-in-production-min-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# development | production (production → Secure cookies unless COOKIE_SECURE overrides)
ENVIRONMENT=development
# Force cookie Secure flag (optional): true / false
# COOKIE_SECURE=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# FRONTEND_URL=https://magikbook.ru

# =============================================================================
# Google OAuth 2.0
# Get credentials at: https://console.cloud.google.com/apis/credentials
# =============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# GOOGLE_REDIRECT_URI=https://magikbook.ru/api/auth/google/callback

# =============================================================================
# VK ID OAuth (client_id = числовой ID приложения в кабинете разработчика)
# Create app at: https://id.vk.com/about — не использовать заблокированные чужие client_id.
# Пример продакшена MagikBook.ru: VK_CLIENT_ID=54542625 (подставьте свой ID приложения).
# Redirect URI в кабинете VK должен совпадать с VK_REDIRECT_URI ниже.
# =============================================================================

VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=http://localhost:8000/api/auth/vk/callback
# VK_REDIRECT_URI=https://magikbook.ru/api/auth/vk/callback

# =============================================================================
# VK Publishing (for auto-posting to VK group)
# Get token: https://dev.vk.com/api/access-token/getting-started
#
# Важно: photos.getWallUploadServer / wall.post с фото требуют пользовательский access token
# с правами wall, photos, groups (админ группы). Сервисный ключ сообщества даёт
# VK error 27 "method is unavailable with group auth" — пост не создаётся.
#
# Реализация API: wall.post / photos.saveWallPhoto шлют параметры в теле POST; передача в query
# давала HTTP 414 на длинных промптах. См. src/services/vk_publisher.py и README.
# =============================================================================

# Ключ с правами wall, photos, groups для группы ниже (выдаётся тем же приложением, что и OAuth, или отдельным standalone).
VK_ACCESS_TOKEN=
# Сервисный ключ из кабинета VK (другой scope; magikbook-api для wall.post его не подставляет).
VK_SERVICE_ACCESS_TOKEN=
# Пример: club227656789 → VK_GROUP_ID=-227656789 (иначе -123456789)
VK_GROUP_ID=-123456789

# =============================================================================
# Telegram Bot (for auth and publishing)
# Create bot with @BotFather
# =============================================================================

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel_username
# Or numeric ID: -1001234567890

# =============================================================================
# File Upload Settings
# =============================================================================

UPLOAD_DIR=./uploads/temp
MAX_FILE_SIZE=52428800  # 50 MB in bytes
FILE_CLEANUP_DAYS=7

# =============================================================================
# AI Generation (Google Gemini)
# Get API key: https://makersuite.google.com/app/apikey
# Leave empty to start API without generation (/api/generate returns 503)
# =============================================================================

GOOGLE_API_KEY=
GEMINI_STREAM_TIMEOUT_SECONDS=45
# Автогенерация «Заклинания дня» через arq cron (00:00 UTC). По умолчанию отключена.
# Включить: DAILY_PROMPT_ENABLED=true
DAILY_PROMPT_ENABLED=false

# =============================================================================
# Email OTP (required for email login)
# =============================================================================
# Resend: на VPS часто заблокирован исходящий SMTP (465) — API идёт по HTTPS (443).
# Достаточно SMTP_HOST=smtp.resend.com + SMTP_PASSWORD=re_... (ключ), тогда OTP шлётся через API.
# Опционально: RESEND_API_KEY=re_... (перекрывает использование ключа из SMTP_PASSWORD для API).

SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=
# RESEND_API_KEY=
SMTP_FROM=MagikBook <noreply@magikbook.ru>

# =============================================================================
# Optional: External Services
# =============================================================================

# S3 Storage (for future file storage migration)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=

# =============================================================================
# Development Settings
# =============================================================================

DEBUG=true
LOG_LEVEL=INFO
